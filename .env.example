# Prefer OpenAI when present
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Fallback to Gemini when OPENAI_API_KEY is empty/missing
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional one-time bootstrap passwords.
# If app-data/auth/users.json does not exist yet, the server will hash these into that file on first start.
ADMIN_PASSWORD=
BRIAN_PASSWORD=
GUARANG_PASSWORD=

# Optional session settings for local/internal use.
# Use "auto" for localhost HTTP, or "true" when serving behind HTTPS.
SESSION_COOKIE_SECURE=auto
SESSION_MAX_AGE_DAYS=30
